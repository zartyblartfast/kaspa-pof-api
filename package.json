{
  "name": "kaspa-pof-api",
  "version": "0.1.0-alpha.1",
  "description": "General-purpose proof-of-fairness API package using Kaspa/TN10/mainnet evidence",
  "type": "module",
  "license": "MIT",
  "author": "Kaspa PoF API contributors",
  "homepage": "https://github.com/zartyblartfast/kaspa-pof-api#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zartyblartfast/kaspa-pof-api.git"
  },
  "bugs": {
    "url": "https://github.com/zartyblartfast/kaspa-pof-api/issues"
  },
  "keywords": [
    "kaspa",
    "proof-of-fairness",
    "fairness",
    "entropy",
    "verification",
    "tn10"
  ],
  "scripts": {
    "test": "node --test",
    "smoke": "scripts/smoke.sh",
    "smoke:published": "scripts/published-package-smoke.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./src/index.cjs",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs",
      "require": "./src/index.cjs",
      "default": "./src/index.mjs"
    },
    "./browser": {
      "types": "./src/browser.d.ts",
      "import": "./src/browser.mjs",
      "default": "./src/browser.mjs"
    }
  },
  "files": [
    "src/",
    "references/live-tn10-proof-root-anchor-evidence.json",
    "references/live-tn10-proof-root-anchored-evidence.json",
    "references/live-tn10-proof-root-anchored-proof.json",
    "README.md",
    "LICENSE",
    "docs/"
  ]
}
